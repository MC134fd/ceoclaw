# CEOClaw environment configuration
# Copy to .env and fill in values:  cp .env.example .env

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
CEOCLAW_APP_NAME=CEOClaw
CEOCLAW_ENV=development
CEOCLAW_LOG_LEVEL=INFO

# SQLite file path — relative to project root, or absolute
CEOCLAW_DATABASE_PATH=data/ceoclaw.db

# Directory for generated website landing pages
CEOCLAW_WEBSITES_DIR=data/websites

# Agent runtime defaults
CEOCLAW_GOAL_MRR=100.0
CEOCLAW_MAX_CYCLES=20

# ---------------------------------------------------------------------------
# FLock model adapter
# ---------------------------------------------------------------------------
# Set FLOCK_MOCK_MODE=true to run without a live endpoint (demo / CI mode).
# When false, FLOCK_ENDPOINT and FLOCK_API_KEY must be set.
FLOCK_MOCK_MODE=false

# Hosted endpoint — replace with your provider's URL.
# Leave blank only when FLOCK_MOCK_MODE=true.
FLOCK_ENDPOINT=https://api.flock.io/v1/chat/completions

# API key — never commit a real value here.
FLOCK_API_KEY=

# Model name sent in the request payload (check your provider's model list).
FLOCK_MODEL=flock-default

# Auth header strategy:
#   both    — sends both Authorization: Bearer AND x-litellm-api-key (default, max compat)
#   bearer  — OpenAI-style only (Authorization: Bearer <key>)
#   litellm — LiteLLM / OpenClaw VPS-style only (x-litellm-api-key: <key>)
FLOCK_AUTH_STRATEGY=both

FLOCK_TIMEOUT=30
FLOCK_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# OpenAI fallback provider (for website chat generation)
# ---------------------------------------------------------------------------
# If Flock is unavailable, the website generator falls back to OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions

# API mode for OpenAI calls:
#   auto      — use Responses API for gpt-5* models, Chat Completions otherwise (default)
#   responses — force Responses API (/v1/responses) for all models
#   chat      — force Chat Completions API (/v1/chat/completions) for all models
OPENAI_API_MODE=auto

# ---------------------------------------------------------------------------
# Live web research
# ---------------------------------------------------------------------------
# Enables real-time market research via Brave or Google CSE.
# Falls back to deterministic templates when keys are absent.
WEB_RESEARCH_ENABLED=true
WEB_RESEARCH_PROVIDER_ORDER=brave,google
WEB_RESEARCH_MAX_RESULTS=8
WEB_RESEARCH_TIMEOUT=12

# [REQUIRED for Brave] Get key at: https://api.search.brave.com
BRAVE_SEARCH_API_KEY=

# [REQUIRED for Google CSE] https://programmablesearchengine.google.com
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# ---------------------------------------------------------------------------
# Memory backend (cross-run persistence)
# ---------------------------------------------------------------------------
# sqlite = no setup, stores in local DB (default)
# supabase = cloud persistence, requires keys below
MEMORY_BACKEND=sqlite

# [REQUIRED if MEMORY_BACKEND=supabase]
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=public

# ---------------------------------------------------------------------------
# Social publishing
# ---------------------------------------------------------------------------
X_API_KEY=
X_BEARER_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ---------------------------------------------------------------------------
# Email outreach provider: none | sendgrid | resend
# ---------------------------------------------------------------------------
OUTREACH_EMAIL_PROVIDER=none
SENDGRID_API_KEY=
RESEND_API_KEY=
